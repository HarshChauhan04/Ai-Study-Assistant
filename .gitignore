# ========================
# ROOT GITIGNORE
# ========================

# Node modules
node_modules/
*/node_modules/

# Environment variables — NEVER commit these!
.env
.env.local
.env.production
.env.*.local
backend/.env
frontend/.env

# Build outputs
dist/
build/
.next/
out/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS / IDE files
.DS_Store
Thumbs.db
.vscode/settings.json
.idea/

# Uploads folder (local PDF uploads)
backend/uploads/*
!backend/uploads/.gitkeep

# Coverage
coverage/

# Misc
*.pem
.cache/
.parcel-cache/
