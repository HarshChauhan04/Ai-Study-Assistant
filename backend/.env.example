# StudyFlow AI — Backend Environment Variables
# Copy this file to .env and fill in your values

# Server
PORT=5000
NODE_ENV=production

# MongoDB Atlas Connection String
MONGO_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/ai-study-assistant?appName=Cluster0

# JWT Secret Key (use a long random string in production)
JWT_SECRET=your_super_secret_jwt_key_here_min_32_chars

# Groq AI API Key (get from https://console.groq.com)
GROQ_API_KEY=gsk_your_groq_api_key_here

# CORS — your Vercel frontend URL (comma-separated for multiple)
CORS_ORIGIN=https://your-app.vercel.app

# Optional: Redis URL for rate limiting cache (leave blank to use in-memory)
# REDIS_URL=redis://...
